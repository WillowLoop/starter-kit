APP_ENV=development
APP_DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:__POSTGRES_PASSWORD__@localhost:5432/aipoweredmakers
# REDIS_URL=redis://localhost:6379/0  # Optional. Enable when adding caching/sessions.
# CORS_ORIGINS=https://yourdomain.com  # Default: localhost:3000-3015 (dev). Set explicitly in production.
SECRET_KEY=__SECRET_KEY__
LOG_LEVEL=DEBUG
RATE_LIMIT_DEFAULT=100/minute  # Per IP. Behind proxy: configure X-Forwarded-For trust.

# Sentry (optional — app works without it)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0  # Local dev: set to 1.0 for full tracing. Production: 0.1-0.2.
SENTRY_ENVIRONMENT=

# Docker Compose (postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=aipoweredmakers
