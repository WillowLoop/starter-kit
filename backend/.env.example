APP_ENV=development
APP_DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:__POSTGRES_PASSWORD__@localhost:5432/aipoweredmakers  # ⚠ Port must match POSTGRES_PORT — app warns on mismatch at startup. Production: append ?sslmode=require
# REDIS_URL=redis://localhost:6379/0  # Optional. Enable when adding caching/sessions.
# CORS_ORIGINS=https://yourdomain.com  # Default: localhost:3000-3015 (dev). Set explicitly in production.
SECRET_KEY=__SECRET_KEY__
LOG_LEVEL=DEBUG
RATE_LIMIT_DEFAULT=100/minute  # Per IP. Behind proxy: configure X-Forwarded-For trust.

# Sentry (optional — app works without it)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0  # Local dev: set to 1.0 for full tracing. Production: 0.1-0.2.
SENTRY_ENVIRONMENT=

# Docker Compose (postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=aipoweredmakers  # Change per project to avoid database name conflicts.
POSTGRES_PORT=5432  # Change per project to avoid port conflicts when running multiple apps.

# Docker Compose (production deployment)
DOCKER_IMAGE_ORG=your-github-username
DOCKER_IMAGE_REPO=your-repo-name
BACKEND_IMAGE_TAG=latest  # Set by deploy workflow (e.g., sha-abc123 or backend-v0.1.0)
FRONTEND_IMAGE_TAG=latest  # Set by deploy workflow (e.g., sha-abc123 or frontend-v0.1.0)
BACKEND_DOMAIN=api.your-domain.com
FRONTEND_DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com  # Let's Encrypt certificate notifications
NEXT_PUBLIC_API_URL=https://api.your-domain.com
