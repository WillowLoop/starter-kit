# Copy to .env.local for local development (auto-loaded by Next.js, gitignored).

# API backend URL (used in server and client components)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Sentry (optional — app works without it)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0  # Local dev: set to 1 for full tracing. Production: 0.1-0.2.
